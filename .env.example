DB_PASSWORD=your-secure-password
GRAFANA_PASSWORD=your-grafana-password

# Optional: set an API key to require X-API-Key header on requests
# Leave empty to allow unauthenticated access (fine if behind VPN/firewall)
API_KEY=generate-a-long-random-token-for-production

# Optional image pins. Override only when deliberately upgrading.
TIMESCALE_IMAGE=timescale/timescaledb:2.17.2-pg16
GRAFANA_IMAGE=grafana/grafana-oss:11.2.0

# Remote apps-vm deploy mode. Most users should keep `compose`, which
# starts the bundled TimescaleDB service. Operators with an existing
# Postgres/TimescaleDB host can deploy with `external`; deploy.sh then
# points API, worker, migrations, Grafana, and the optional Home
# Assistant bridge at the same external database.
HEALTH_DATA_HUB_DATABASE_MODE=compose
HEALTH_DATA_HUB_API_PORT=18080
HEALTH_DATA_HUB_GRAFANA_PORT=3300
HEALTH_DATA_HUB_DB_PUBLISH_PORT=15432
HEALTH_DATA_HUB_DB_PORT=5432
HEALTH_DATA_HUB_DB_HOST=postgres.example.internal
HEALTH_DATA_HUB_DB_NAME=healthsave
HEALTH_DATA_HUB_DB_USER=healthsave

# LLM provider for the Phase 1 AI analysis engine. The local-first
# default runs fully on-device via Ollama - no data ever leaves the
# Docker network. Change these only if you explicitly want to use a
# cloud provider (in which case also set the provider's api_key in
# config.yaml).
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
LLM_API_KEY=

# OLLAMA_MODEL - which model to pull and use for AI narrative insights.
# `setup.sh` picks one based on your system RAM + GPU; you can edit here
# any time. Approximate tiers (Ollama Metal on Apple Silicon / CUDA on NVIDIA):
#   <  6 GB RAM  → disable AI (too small for useful models)
#   6–10 GB      → llama3.2:1b   (~1.3 GB) [Apple]   |  gemma3:4b (~3 GB) [NVIDIA]
#   10–18 GB     → gemma3:4b     (~3 GB)  [Apple]    |  qwen3:8b  (~5 GB) [NVIDIA]
#   18–36 GB     → qwen3:8b      (~5 GB)  [Apple]    |  qwen3:14b (~9 GB) [NVIDIA]
#   36–96 GB     → qwen3:14b     (~9 GB)  [Apple]    |  gemma3:27b (~17 GB) [NVIDIA]
#   >  96 GB     → llama3.3:70b  (~40 GB)            |  llama4:scout (MoE, ~40 GB)
# 2026 generations (Llama 3.3 / 4, Qwen 3, Gemma 3) are recommended; the
# default below stays on llama3.1:8b for backward-compatibility with
# existing pulls. Any Ollama model tag works; see https://ollama.com/library
OLLAMA_MODEL=llama3.1:8b

# setup.sh writes ./config.yaml and points Compose at it. Manual quick-start
# users can keep the example config unless they want to enable AI.
ANALYSIS_CONFIG_FILE=./config.yaml.example

# ─── OAuth/token-based source plugins (Whoop, Amazfit/Zepp) ─────────────
#
# HDH_TOKEN_ENC_KEY is the Fernet key used to encrypt third-party
# OAuth tokens at rest in the oauth_tokens table (migration 008).
# Generate one with:
#   docker compose run --rm --no-deps --build api python -c "from auth import generate_key; print(generate_key())"
# It MUST be a URL-safe base64-encoded 32-byte key (Fernet format).
# Rotation: swap to MultiFernet([new, old]) in code, rewrite rows, drop old.
HDH_TOKEN_ENC_KEY=

# Whoop developer credentials (https://developer.whoop.com).
# Required only if you enable the Whoop source plugin (P2+).
# The plugin polls Whoop on a worker schedule; tokens are refreshed
# atomically and the prior refresh_token is invalidated by Whoop on
# success, so partial-write races are not safe — see the plugin README.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=

# Amazfit / Zepp credentials. The plugin does NOT carry your Zepp
# password — operators obtain an app_token externally (via the
# `huami-token` PyPI CLI, or by capturing the Zepp app's HTTPS traffic
# per `zepp-health-cli`'s instructions) and hand it to
# `scripts/amazfit_authorize.py`. The token is stored encrypted in
# oauth_tokens; on expiry the worker fails loud and the operator
# re-extracts. AMAZFIT_REGION is one of us | eu | cn (default us).
#
# ⚠️ Zepp has no public API. The plaintext-password v2/client/login
# flow this plugin originally used is dead as of 2026-05-22; see
# plugins/sources/amazfit/README.md for the current procedure.
AMAZFIT_APP_TOKEN=
AMAZFIT_USER_ID=
AMAZFIT_REGION=us

# Worker poll schedule. Crontab expression — leave blank to disable.
# Zepp's data endpoints do not publish a rate limit; */30 (every 30
# minutes) matches Whoop's default and is plenty for a single account.
AMAZFIT_POLL_CRON=

# Enable the Whoop poll job in the worker. Crontab expression — leave
# blank to disable. Whoop's rate limit is 100 req/min; */30 * * * *
# (every 30 minutes) is plenty for a single-user poll.
WHOOP_POLL_CRON=

# ─── Optional Home Assistant MQTT bridge ───────────────────────────────
#
# Leave disabled unless you want retained MQTT discovery + state topics
# for Home Assistant. Use:
#   docker compose --profile home-assistant up -d homeassistant-mqtt
# or add --profile mosquitto to run the bundled broker as well.
HA_MQTT_ENABLED=false
HA_MQTT_BROKER=mqtt
HA_MQTT_PORT=1883
HA_MQTT_USERNAME=
HA_MQTT_PASSWORD=
HA_MQTT_DISCOVERY_PREFIX=homeassistant
HA_MQTT_STATE_TOPIC_PREFIX=healthsave
HA_MQTT_DEVICE_IDENTIFIER=healthsave
HA_MQTT_DEVICE_NAME=HealthSave
HA_MQTT_PUBLISH_INTERVAL_SECONDS=60
MOSQUITTO_PORT=1883
