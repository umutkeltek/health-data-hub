# HealthSave Observatory - analysis configuration
#
# This file configures the Phase 2 AI analysis engine: schedule of
# analysis jobs, LLM provider, and notification delivery. All secrets
# (API keys, database passwords) live in .env, NOT in this file.
#
# Copy to config.yaml and edit as desired. The example values below
# are safe defaults: ingestion works immediately, while AI briefing stays
# off until setup.sh or you explicitly enable daily_briefing below.

# Each job's `enabled` flag can also be set from .env — handy for container
# deploys that mount this example file read-only and can't edit it:
#   ANALYSIS_DAILY_BRIEFING_ENABLED, ANALYSIS_WEEKLY_SUMMARY_ENABLED,
#   ANALYSIS_ANOMALY_DETECTION_ENABLED, ANALYSIS_TREND_ANALYSIS_ENABLED,
#   ANALYSIS_CORRELATION_ANALYSIS_ENABLED, ANALYSIS_RECOVERY_ENABLED
# (any of 1/true/yes/on). The .env value wins over the value here.
analysis:
  daily_briefing:
    enabled: false
    cron: "0 7 * * *"          # Every day at 7:00 AM local time
    lookback_days: 1
    baseline_days: 30

  weekly_summary:
    enabled: false
    cron: "0 8 * * 1"          # Mondays at 8:00 AM local time
    lookback_days: 7
    baseline_days: 28

  anomaly_detection:
    enabled: false
    cron: "*/30 * * * *"       # Every 30 minutes
    on_ingest: true            # Also run after a successful batch sync
    cooldown_minutes: 15       # Minimum time between runs
    sensitivity: "normal"      # low | normal | high (maps to stddev threshold)

  trend_analysis:
    enabled: false
    cron: "0 9 * * 1"          # Mondays at 9:00 AM
    period_days: 30

  correlation_analysis:
    enabled: false
    cron: "0 10 1 * *"         # 1st of month at 10:00 AM
    period_days: 90

  recovery:
    enabled: false
    cron: "0 6 * * *"          # Every day at 6:00 AM, ahead of the briefing
    lookback_days: 1
    baseline_days: 30          # Open Recovery Score (no LLM) — supplement §3

llm:
  # Local-first default. No data leaves the Docker network unless you
  # change this to a cloud provider and supply an api_key.
  provider: "ollama"
  model: "llama3.1:8b"
  base_url: "http://ollama:11434"
  api_key: ""                   # Left empty for ollama; set for cloud providers
  temperature: 0.3
  max_tokens: 1000
  # When a cloud provider is used (with allow_cloud_egress: true), the assembled
  # narration prompt is scrubbed of identifiers — emails, phone numbers, opaque
  # IDs, names — before it leaves the host. The local Ollama path is never
  # redacted. Leave on unless you have a specific reason to disable it.
  redact_cloud_prompts: true
  # redaction_salt: ""          # set to pseudonymize the same value consistently
  # Optional fallback list, tried in order if the primary provider fails.
  fallback: []
  # Example cloud fallback (uncomment + set api_key in secrets):
  # fallback:
  #   - provider: "openai"
  #     model: "gpt-4o-mini"

notifications:
  # Outbound webhook (POST JSON payload). Empty = disabled.
  webhook_url: ""
  mqtt:
    enabled: false
    broker: "localhost"
    port: 1883
    topic_prefix: "health/insights"

# Optional Home Assistant MQTT bridge. This is separate from Grafana:
# Grafana reads TimescaleDB; Home Assistant gets retained MQTT entities.
# Prefer environment variables in Docker (`HA_MQTT_*`) for deployment.
home_assistant:
  mqtt:
    enabled: false
    broker: "localhost"
    port: 1883
    discovery_prefix: "homeassistant"
    # Fresh installs use the HealthSave MQTT shape:
    # state topic `healthsave/sensor/state`, discovery under
    # `homeassistant/sensor/healthsave/<metric>/config`.
    # Legacy users can keep an old namespace alive during migration with
    # HA_MQTT_LEGACY_* env vars while the primary shape stays HealthSave.
    state_topic_prefix: "healthsave"
    device_identifier: "healthsave"
    device_name: "HealthSave"
    publish_interval_seconds: 60

# Agents — Phase 7-C autonomous-agent supervisor (apps/agents).
#
# Empty `enabled:` by default — no agent runs without explicit opt-in.
# This protects the local-first deploy from surprise autonomy. The
# `defaults:` block applies to every enabled agent; `plugins:` overrides
# specific ids (use the manifest `id`, not the folder slug).
#
# Enabling an unknown plugin id is a fail-loud startup error: silent
# skip would let a typo masquerade as a working agent.
agents:
  enabled: []                         # opt-in allowlist of manifest ids
  defaults:
    tick_interval_seconds: 60         # one tick per minute by default
    timeout_seconds: 5                # per-call deadline (observe/propose/persist)
    restart_lookback_seconds: 3600    # on restart, replay up to 1h of observations
  plugins:
    # Example (Phase 7-D will ship this plugin):
    # hdh.agents.anomaly_watcher:
    #   tick_interval_seconds: 60
    {}
