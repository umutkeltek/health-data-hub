        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "points": {
          "items": {
            "maxItems": 2,
            "minItems": 2,
