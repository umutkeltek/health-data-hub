    "NormalizedMeasurement": {
      "additionalProperties": false,
      "description": "One canonical sample after a Source plugin has parsed it.\n\nWraps a :class:`Measurement` and pins the raw payload it derives\nfrom. The split lets us evolve normalization independently of the\ncanonical wire shape.",
      "properties": {
        "measurement": {
          "$ref": "#/$defs/Measurement"
