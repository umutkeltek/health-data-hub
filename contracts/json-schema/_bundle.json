{
  "$defs": {
    "ActionDecision": {
      "additionalProperties": false,
      "description": "The policy layer's verdict on a proposal.",
      "properties": {
        "decided_at": {
          "format": "date-time",
          "title": "Decided At",
          "type": "string"
        },
        "decided_by": {
          "enum": [
            "user",
            "policy",
            "auto"
          ],
          "title": "Decided By",
          "type": "string"
        },
        "decision": {
          "enum": [
            "approved",
            "rejected",
            "deferred"
          ],
          "title": "Decision",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "proposal_id": {
          "format": "uuid",
          "title": "Proposal Id",
          "type": "string"
        },
        "rationale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rationale"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "proposal_id",
        "decided_at",
        "decision",
        "decided_by"
      ],
      "title": "ActionDecision",
      "type": "object"
    },
    "ActionExecution": {
      "additionalProperties": false,
      "description": "The result of executing an approved proposal.",
      "properties": {
        "decision_id": {
          "format": "uuid",
          "title": "Decision Id",
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "executed_at": {
          "format": "date-time",
          "title": "Executed At",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "proposal_id": {
          "format": "uuid",
          "title": "Proposal Id",
          "type": "string"
        },
        "result": {
          "default": {},
          "title": "Result",
          "type": "object"
        },
        "status": {
          "enum": [
            "succeeded",
            "failed",
            "skipped"
          ],
          "title": "Status",
          "type": "string"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "proposal_id",
        "decision_id",
        "executed_at",
        "status"
      ],
      "title": "ActionExecution",
      "type": "object"
    },
    "ActionProposal": {
      "additionalProperties": false,
      "description": "An action the agent wants to take. Every state mutation begins here.\n\n``capability`` references the manifest-declared capability the\nagent claims is sufficient to execute this action; the policy\nlayer cross-checks.",
      "properties": {
        "action_kind": {
          "enum": [
            "notify",
            "create_experiment",
            "create_briefing",
            "request_user_input",
            "tag_measurement"
          ],
          "title": "Action Kind",
          "type": "string"
        },
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "payload": {
          "title": "Payload",
          "type": "object"
        },
        "proposed_at": {
          "format": "date-time",
          "title": "Proposed At",
          "type": "string"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "run_id": {
          "format": "uuid",
          "title": "Run Id",
          "type": "string"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "run_id",
        "proposed_at",
        "action_kind",
        "payload",
        "rationale",
        "capability"
      ],
      "title": "ActionProposal",
      "type": "object"
    },
    "AgentArtifact": {
      "additionalProperties": false,
      "description": "A persisted output of an agent run \u2014 narrative, chart, plan.",
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "narrative",
            "chart_spec",
            "experiment_plan",
            "intervention_proposal"
          ],
          "title": "Kind",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "payload": {
          "title": "Payload",
          "type": "object"
        },
        "run_id": {
          "format": "uuid",
          "title": "Run Id",
          "type": "string"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "run_id",
        "kind",
        "payload",
        "created_at"
      ],
      "title": "AgentArtifact",
      "type": "object"
    },
    "AgentEvent": {
      "additionalProperties": false,
      "description": "One event in the agent timeline.\n\nStreamed over Server-Sent Events to ``apps/web``'s agent activity\nfeed; persisted as the audit trail. The dashboard reads this\nshape directly via the generated TS client.",
      "properties": {
        "emitted_at": {
          "format": "date-time",
          "title": "Emitted At",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "run_started",
            "run_completed",
            "run_failed",
            "observation",
            "proposal_created",
            "proposal_approved",
            "proposal_rejected",
            "execution_succeeded",
            "execution_failed",
            "artifact_created"
          ],
          "title": "Kind",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "payload": {
          "title": "Payload",
          "type": "object"
        },
        "run_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Id"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "emitted_at",
        "kind",
        "payload"
      ],
      "title": "AgentEvent",
      "type": "object"
    },
    "AgentRun": {
      "additionalProperties": false,
      "description": "One execution of an agent. The aggregate root for the lifecycle.",
      "properties": {
        "ended_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ended At"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "plugin_id": {
          "title": "Plugin Id",
          "type": "string"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "status": {
          "enum": [
            "running",
            "completed",
            "failed",
            "cancelled"
          ],
          "title": "Status",
          "type": "string"
        },
        "trigger_kind": {
          "enum": [
            "cron",
            "ingest_event",
            "metric_threshold",
            "manual"
          ],
          "title": "Trigger Kind",
          "type": "string"
        },
        "trigger_metadata": {
          "default": {},
          "title": "Trigger Metadata",
          "type": "object"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "plugin_id",
        "started_at",
        "status",
        "trigger_kind"
      ],
      "title": "AgentRun",
      "type": "object"
    },
    "AgentSpec": {
      "additionalProperties": false,
      "description": "An agent's declared identity. Loaded from the plugin manifest.\n\nProcess-level metadata, not user data \u2014 does not extend\n:class:`WithOwnership`.",
      "properties": {
        "capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Capabilities",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "plugin_id": {
          "title": "Plugin Id",
          "type": "string"
        },
        "triggers": {
          "items": {
            "enum": [
              "cron",
              "ingest_event",
              "metric_threshold",
              "manual"
            ],
            "type": "string"
          },
          "title": "Triggers",
          "type": "array"
        },
        "version": {
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "plugin_id",
        "version",
        "name",
        "description",
        "triggers",
        "capabilities"
      ],
      "title": "AgentSpec",
      "type": "object"
    },
    "Annotation": {
      "additionalProperties": false,
      "description": "A point or range marker on a chart \u2014 anomaly, intervention, event.",
      "properties": {
        "at": {
          "format": "date-time",
          "title": "At",
          "type": "string"
        },
        "color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Color"
        },
        "end": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End"
        },
        "kind": {
          "enum": [
            "point",
            "range"
          ],
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "at",
        "text"
      ],
      "title": "Annotation",
      "type": "object"
    },
    "ChartSpec": {
      "additionalProperties": false,
      "description": "Declarative chart spec \u2014 what to render, not how.\n\nThe web app maps this to whichever chart library is current\n(Recharts/ECharts/Tremor); swapping the library is a ``apps/web``\njob, not a contract change.",
      "properties": {
        "aggregation": {
          "default": "raw",
          "enum": [
            "raw",
            "hourly",
            "daily"
          ],
          "title": "Aggregation",
          "type": "string"
        },
        "annotations_enabled": {
          "default": true,
          "title": "Annotations Enabled",
          "type": "boolean"
        },
        "chart_kind": {
          "enum": [
            "line",
            "bar",
            "area",
            "scatter"
          ],
          "title": "Chart Kind",
          "type": "string"
        },
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "range_days": {
          "default": 30,
          "exclusiveMinimum": 0,
          "title": "Range Days",
          "type": "integer"
        }
      },
      "required": [
        "metric",
        "chart_kind"
      ],
      "title": "ChartSpec",
      "type": "object"
    },
    "Claim": {
      "additionalProperties": false,
      "description": "One assertion inside a narrative, with optional evidence + uncertainty.",
      "properties": {
        "evidence": {
          "default": [],
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          },
          "title": "Evidence",
          "type": "array"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "uncertainty": {
          "anyOf": [
            {
              "$ref": "#/$defs/Uncertainty"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "text"
      ],
      "title": "Claim",
      "type": "object"
    },
    "Device": {
      "additionalProperties": false,
      "description": "A physical or logical device emitting samples for a Source.",
      "properties": {
        "hardware_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hardware Id"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "source_id": {
          "format": "uuid",
          "title": "Source Id",
          "type": "string"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "source_id"
      ],
      "title": "Device",
      "type": "object"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "description": "A pointer to a piece of evidence backing a claim.",
      "properties": {
        "kind": {
          "enum": [
            "measurement",
            "finding",
            "observation",
            "external"
          ],
          "title": "Kind",
          "type": "string"
        },
        "ref": {
          "title": "Ref",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "IngestionError": {
      "additionalProperties": false,
      "description": "One error captured during an IngestionRun. Append-only.",
      "properties": {
        "error_kind": {
          "title": "Error Kind",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "occurred_at": {
          "format": "date-time",
          "title": "Occurred At",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "payload_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Payload Ref"
        },
        "run_id": {
          "format": "uuid",
          "title": "Run Id",
          "type": "string"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "run_id",
        "occurred_at",
        "error_kind",
        "message"
      ],
      "title": "IngestionError",
      "type": "object"
    },
    "IngestionRun": {
      "additionalProperties": false,
      "description": "One execution of a Source plugin pulling/receiving data.",
      "properties": {
        "ended_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ended At"
        },
        "errors_count": {
          "default": 0,
          "title": "Errors Count",
          "type": "integer"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "measurements_count": {
          "default": 0,
          "title": "Measurements Count",
          "type": "integer"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "source_id": {
          "format": "uuid",
          "title": "Source Id",
          "type": "string"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "status": {
          "enum": [
            "running",
            "succeeded",
            "failed",
            "partial",
            "cancelled"
          ],
          "title": "Status",
          "type": "string"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "source_id",
        "started_at",
        "status"
      ],
      "title": "IngestionRun",
      "type": "object"
    },
    "Insight": {
      "additionalProperties": false,
      "description": "A structured observation about the user's data.\n\nSeverity matches the existing ``analysis.types.Severity`` literal so\nthe v1 statistical engine output round-trips cleanly into v2 narratives.",
      "properties": {
        "claims": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Claim"
          },
          "title": "Claims",
          "type": "array"
        },
        "metric": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric"
        },
        "severity": {
          "default": "info",
          "enum": [
            "info",
            "watch",
            "alert"
          ],
          "title": "Severity",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "summary"
      ],
      "title": "Insight",
      "type": "object"
    },
    "Measurement": {
      "additionalProperties": false,
      "description": "The canonical health measurement.\n\nTime-instant samples set ``interval_start == interval_end``.\nTime-interval samples (sleep stages, workouts, ECG) set both.",
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "device_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Id"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "interval_end": {
          "format": "date-time",
          "title": "Interval End",
          "type": "string"
        },
        "interval_start": {
          "format": "date-time",
          "title": "Interval Start",
          "type": "string"
        },
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "normalization_version": {
          "default": "v1",
          "title": "Normalization Version",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        },
        "source_id": {
          "format": "uuid",
          "title": "Source Id",
          "type": "string"
        },
        "unit": {
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        },
        "workspace_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "metric",
        "unit",
        "value",
        "interval_start",
        "interval_end",
        "source_id",
        "provenance"
      ],
      "title": "Measurement",
      "type": "object"
    },
    "NarrativeArtifact": {
      "additionalProperties": false,
      "description": "A streamable narrative \u2014 daily briefing, weekly summary, etc.\n\nThe wire shape is the *persisted* form. Streaming chunks go over\nSSE during render; once complete, the whole artifact is one row\nin this shape. The dashboard's ``BriefingCard`` reads this.",
      "properties": {
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "insights": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Insight"
          },
          "title": "Insights",
          "type": "array"
        },
        "kind": {
          "enum": [
            "daily_briefing",
            "weekly_summary",
            "anomaly_explanation",
            "intervention_proposal"
          ],
          "title": "Kind",
          "type": "string"
        },
        "narrator_plugin_id": {
          "title": "Narrator Plugin Id",
          "type": "string"
        },
        "narrator_version": {
          "title": "Narrator Version",
          "type": "string"
        },
        "owner_id": {
          "default": "00000000-0000-0000-0000-000000000001",
          "format": "uuid",
          "title": "Owner Id",
          "type": "string"
