    "/api/insights/anomalies": {
      "get": {
        "description": "Return recent anomaly findings from the analysis engine.\n\nReads ``analysis_findings`` where ``finding_type='anomaly'``, ordered\nby ``created_at DESC``. Optional ``since`` limits rows to those\ncreated at-or-after the timestamp. Optional ``severity`` is a\ncomma-separated list (``info,watch,alert``) matched against the\nfinding's severity column.",
        "operationId": "insights_anomalies_api_insights_anomalies_get",
        "parameters": [
          {
            "description": "ISO-8601 lower bound on created_at",
            "in": "query",
            "name": "since",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "format": "date-time",
                  "type": "string"
                },
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "ISO-8601 lower bound on created_at",
              "title": "Since"
            }
          },
          {
            "description": "Comma-separated list: info, watch, alert",
            "in": "query",
            "name": "severity",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Comma-separated list: info, watch, alert",
              "title": "Severity"
            }
          },
          {
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "default": "",
              "title": "X-Api-Key",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnomaliesListResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Insights Anomalies"
      }
    },
