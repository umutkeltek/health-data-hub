  "info": {
    "title": "Health Data Hub",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/apple/batch": {
      "post": {
        "description": "Receive a metric batch from HealthSave iOS app.\n\nExpected payload:\n{\n    \"metric\": \"heart_rate\",\n    \"batch_index\": 0,\n    \"total_batches\": 1,\n    \"samples\": [\n        {\"date\": \"2024-01-15T10:30:00Z\", \"qty\": 72, \"source\": \"Apple Watch\"},\n        ...\n    ]\n}",
        "operationId": "apple_batch_api_apple_batch_post",
        "parameters": [
          {
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "default": "",
              "title": "X-Api-Key",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Apple Batch"
      }
    },
    "/api/apple/status": {
      "get": {
        "description": "Return record counts so the iOS app knows what's synced.",
