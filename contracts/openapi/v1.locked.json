    "/api/insights/trigger": {
      "post": {
        "description": "Run an ad-hoc analysis job inline.\n\n``daily_briefing`` and ``trend_analysis`` run synchronously against\n``app.state.analysis_engine``. Future job types (weekly,\ncorrelation, etc.) should dispatch via ``request.app.state.scheduler``\nonce their engine methods land.",
        "operationId": "insights_trigger_api_insights_trigger_post",
        "parameters": [
          {
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "default": "",
              "title": "X-Api-Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/TriggerRequest"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Body"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TriggerResponse"
                }
              }
            },
