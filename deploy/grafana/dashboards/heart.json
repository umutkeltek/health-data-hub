{
  "uid": "heart-cardio",
  "title": "Heart & Cardiovascular",
  "tags": ["health", "heart", "cardio"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30d", "to": "now" },
  "refresh": "5m",
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "editable": true,
  "graphTooltip": 1,
  "style": "dark",
  "panels": [
    {
      "id": 1,
      "title": "Latest Resting HR",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "healthsave-pg" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "healthsave-pg" },
          "rawSql": "SELECT value::int AS bpm FROM quantity_samples WHERE metric_name='resting_heart_rate' AND device_id IN ($device) ORDER BY time DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bpm",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#73BF69", "value": 50 },
              { "color": "green", "value": 55 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
