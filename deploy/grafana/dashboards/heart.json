        {
          "datasource": { "type": "postgres", "uid": "healthsave-pg" },
          "rawSql": "SELECT value_ms::int FROM hrv WHERE device_id IN ($device) ORDER BY time DESC LIMIT 1",
          "format": "table",
          "refId": "A"
