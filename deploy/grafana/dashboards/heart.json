    {
      "id": 11,
      "title": "Heart Rate Zones Distribution",
      "description": "Time spent in each heart rate zone",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "postgres", "uid": "healthsave-pg" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "healthsave-pg" },
          "rawSql": "SELECT \n  CASE \n    WHEN bpm < 60 THEN 'Rest (<60)'\n    WHEN bpm < 100 THEN 'Normal (60-100)'\n    WHEN bpm < 140 THEN 'Moderate (100-140)'\n    WHEN bpm < 170 THEN 'Hard (140-170)'\n    ELSE 'Max (170+)'\n  END AS zone,\n  count(*) AS samples\nFROM heart_rate WHERE $__timeFilter(time) AND device_id IN ($device) AND source_id IN ($source)\nGROUP BY 1 ORDER BY min(bpm)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rest (<60)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#56A6F0" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Normal (60-100)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Moderate (100-140)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FADE2A" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Hard (140-170)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Max (170+)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "values": true,
          "calcs": [],
          "fields": "/^samples$/"
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "displayLabels": ["percent"]
      }
    },
