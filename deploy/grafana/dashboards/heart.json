    {
      "id": 5,
      "title": "Heart Rate Timeline",
      "description": "Heart rate over time, colored by context (resting, walking, continuous)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "healthsave-pg" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "healthsave-pg" },
          "rawSql": "SELECT time_bucket('1 hour', time) AS time, avg(bpm)::numeric(5,1) AS bpm FROM heart_rate WHERE $__timeFilter(time) AND device_id IN ($device) AND source_id IN ($source) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bpm",
          "min": 40,
          "max": 200,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 8,
            "gradientMode": "scheme",
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": false,
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "BPM",
            "axisPlacement": "auto",
            "scaleDistribution": {
              "type": "linear"
            },
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "thresholdsStyle": {
              "mode": "dashed"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 170 }
            ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "resting" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "walking" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "continuous" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["mean", "max", "min"]
        }
      }
    },
