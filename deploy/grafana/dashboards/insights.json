          "rawSql": "SELECT time AS time, value AS \"Recovery Score\"\nFROM quantity_samples WHERE metric_name = 'recovery_score' AND $__timeFilter(time) AND device_id IN ($device) ORDER BY 1",
          "format": "table",
          "refId": "A"
        },
        {
          "datasource": {"type": "postgres", "uid": "healthsave-pg"},
          "rawSql": "SELECT time, sum(value) AS \"Sleep Hours\"\nFROM (\n  SELECT date_trunc('day', ss.start_time) AS time,\n    sum(ss.total_duration_ms) / 3600000.0 AS value\n  FROM sleep_sessions ss\n  WHERE $__timeFilter(ss.start_time) AND ss.device_id IN ($device)\n  GROUP BY 1\n  UNION ALL\n  SELECT date_trunc('day', qs.time) AS time, avg(qs.value) AS value\n  FROM quantity_samples qs\n  WHERE qs.metric_name = 'sleep_duration_hours' AND $__timeFilter(qs.time) AND qs.device_id IN ($device)\n  GROUP BY 1\n) x\nGROUP BY time ORDER BY time",
