    {
      "id": 6,
      "title": "Sleep Duration: Apple Watch vs Whoop",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "postgres", "uid": "healthsave-pg"},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "healthsave-pg"},
          "rawSql": "SELECT time, metric, sum(value) AS value\nFROM (\n  SELECT date_trunc('day', ss.start_time) AS time, d.device_type AS metric,\n    sum(ss.total_duration_ms) / 3600000.0 AS value\n  FROM sleep_sessions ss JOIN devices d ON d.id = ss.device_id\n  WHERE $__timeFilter(ss.start_time) AND ss.device_id IN ($device)\n  GROUP BY 1, d.device_type\n  UNION ALL\n  SELECT date_trunc('day', qs.time) AS time, COALESCE(qs.source_id, d.device_type, 'Unknown') AS metric,\n    avg(qs.value) AS value\n  FROM quantity_samples qs JOIN devices d ON d.id = qs.device_id\n  WHERE qs.metric_name = 'sleep_duration_hours' AND $__timeFilter(qs.time) AND qs.device_id IN ($device)\n  GROUP BY 1, 2\n) x\nGROUP BY time, metric ORDER BY time",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {"mode": "normal", "group": "A"},
            "lineWidth": 1,
            "spanNulls": false,
            "axisCenteredZero": false,
            "showPoints": "never",
            "barAlignment": 0
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 7,
      "title": "Sleep Efficiency by Device",
      "type": "bargauge",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 24},
      "datasource": {"type": "postgres", "uid": "healthsave-pg"},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "healthsave-pg"},
          "rawSql": "SELECT metric, avg(value) AS value\nFROM (\n  SELECT d.device_type AS metric,\n    CASE WHEN (ss.total_duration_ms + COALESCE(ss.awake_ms, 0)) > 0\n      THEN ss.total_duration_ms::float / (ss.total_duration_ms + COALESCE(ss.awake_ms, 0)) * 100.0\n    END AS value\n  FROM sleep_sessions ss JOIN devices d ON d.id = ss.device_id\n  WHERE $__timeFilter(ss.start_time) AND ss.device_id IN ($device)\n  UNION ALL\n  SELECT COALESCE(qs.source_id, d.device_type, 'Unknown') AS metric, qs.value\n  FROM quantity_samples qs JOIN devices d ON d.id = qs.device_id\n  WHERE qs.metric_name = 'sleep_efficiency_percentage' AND $__timeFilter(qs.time) AND qs.device_id IN ($device)\n) x\nWHERE value IS NOT NULL\nGROUP BY metric",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "green", "value": 85}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
      "id": 8,
      "title": "Sleep Performance by Device",
      "type": "bargauge",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 24},
      "datasource": {"type": "postgres", "uid": "healthsave-pg"},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "healthsave-pg"},
          "rawSql": "SELECT metric, avg(value) AS value\nFROM (\n  SELECT d.device_type AS metric,\n    LEAST((ss.total_duration_ms / 3600000.0) / 8.0 * 100.0, 100.0) AS value\n  FROM sleep_sessions ss JOIN devices d ON d.id = ss.device_id\n  WHERE $__timeFilter(ss.start_time) AND ss.device_id IN ($device) AND ss.total_duration_ms IS NOT NULL\n  UNION ALL\n  SELECT COALESCE(qs.source_id, d.device_type, 'Unknown') AS metric,\n    LEAST(qs.value / 8.0 * 100.0, 100.0) AS value\n  FROM quantity_samples qs JOIN devices d ON d.id = qs.device_id\n  WHERE qs.metric_name = 'sleep_duration_hours' AND $__timeFilter(qs.time) AND qs.device_id IN ($device)\n) x\nWHERE value IS NOT NULL\nGROUP BY metric",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "green", "value": 85}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
