    {
      "id": 6,
      "title": "Avg Sleep Duration (7d)",
      "description": "Average total sleep duration over the last 7 days",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "WITH daily_source AS (SELECT date_trunc('day', start_time) AS day, COALESCE(NULLIF(source_id, ''), 'Unknown') AS source, sum(total_duration_ms) / 3600000.0 AS hours FROM sleep_sessions WHERE start_time >= now() - interval '7 days' AND device_id IN ($device) AND total_duration_ms IS NOT NULL GROUP BY 1, 2), ranked AS (SELECT day, hours, row_number() OVER (PARTITION BY day ORDER BY CASE WHEN hours BETWEEN 0 AND 16 THEN 0 ELSE 1 END, hours DESC) AS rn FROM daily_source) SELECT avg(LEAST(hours, 16)) AS \"Avg Sleep (h)\" FROM ranked WHERE rn = 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "green",
                "value": 7
              }
            ]
          },
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
