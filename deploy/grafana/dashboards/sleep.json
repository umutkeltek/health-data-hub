{
  "uid": "sleep-analysis",
  "title": "Sleep Analysis",
  "tags": [
    "health",
    "sleep"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "5m",
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Sleep Stages Timeline",
      "description": "Sleep stages over time showing transitions between deep, REM, core, and awake states",
      "type": "state-timeline",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT time, stage FROM sleep_stages WHERE stage IN ('core','deep','rem','awake') AND $__timeFilter(time) AND device_id IN ($device) ORDER BY time",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byValue",
              "options": {
                "op": "eq",
                "value": "deep"
              }
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byValue",
              "options": {
                "op": "eq",
                "value": "rem"
              }
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byValue",
              "options": {
                "op": "eq",
                "value": "core"
              }
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "light-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byValue",
              "options": {
                "op": "eq",
                "value": "awake"
              }
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showValue": "auto",
        "rowHeight": 0.8,
        "mergeValues": true,
        "alignValue": "center",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "title": "Sleep Duration Trend",
      "description": "Daily total sleep duration in hours (excluding awake and in-bed stages)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "WITH daily_source AS (SELECT date_trunc('day', start_time) AS time, COALESCE(NULLIF(source_id, ''), 'Unknown') AS source, sum(total_duration_ms) / 3600000.0 AS hours FROM sleep_sessions WHERE $__timeFilter(start_time) AND device_id IN ($device) AND total_duration_ms IS NOT NULL GROUP BY 1, 2), ranked AS (SELECT time, hours, row_number() OVER (PARTITION BY time ORDER BY CASE WHEN hours BETWEEN 0 AND 16 THEN 0 ELSE 1 END, hours DESC) AS rn FROM daily_source) SELECT time, LEAST(hours, 16) AS hours FROM ranked WHERE rn = 1 ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "fixed",
            "fixedColor": "super-light-blue"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "pointSize": 6,
            "lineWidth": 2,
            "showPoints": "always",
            "spanNulls": false,
            "axisBorderShow": false,
            "axisCenteredZero": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "green",
                "value": 7
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 3,
      "title": "Sleep Stage Distribution",
      "description": "Percentage breakdown of time spent in each sleep stage",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "WITH daily_source AS (SELECT date_trunc('day', start_time) AS day, COALESCE(NULLIF(source_id, ''), 'Unknown') AS source, sum(total_duration_ms) / 3600000.0 AS total_hours, sum(deep_ms) / 3600000.0 AS deep_hours, sum(rem_ms) / 3600000.0 AS rem_hours, sum(light_ms) / 3600000.0 AS core_hours, sum(awake_ms) / 3600000.0 AS awake_hours FROM sleep_sessions WHERE $__timeFilter(start_time) AND device_id IN ($device) GROUP BY 1, 2), ranked AS (SELECT *, row_number() OVER (PARTITION BY day ORDER BY CASE WHEN total_hours BETWEEN 0 AND 16 THEN 0 ELSE 1 END, total_hours DESC) AS rn FROM daily_source) SELECT stage AS metric, sum(hours) AS value FROM ranked CROSS JOIN LATERAL (VALUES ('deep', deep_hours), ('rem', rem_hours), ('core', core_hours), ('awake', awake_hours)) AS stages(stage, hours) WHERE rn = 1 AND hours > 0 GROUP BY stage ORDER BY value DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "deep"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rem"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "core"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "light-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "awake"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": [],
          "fields": "/^value$/",
          "values": true
        },
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "percent",
            "value"
          ]
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "displayLabels": [
          "percent"
        ]
      }
    },
