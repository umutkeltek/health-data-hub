    {
      "id": 9,
      "title": "Sleep Efficiency (7d)",
      "description": "Percentage of in-bed time actually spent sleeping over the last 7 days",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 24
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "WITH daily_source AS (SELECT date_trunc('day', start_time) AS day, COALESCE(NULLIF(source_id, ''), 'Unknown') AS source, sum(total_duration_ms) AS sleep_ms, sum(COALESCE(awake_ms, 0)) AS awake_ms, sum(total_duration_ms) / 3600000.0 AS total_hours FROM sleep_sessions WHERE start_time >= now() - interval '7 days' AND device_id IN ($device) GROUP BY 1, 2), ranked AS (SELECT *, row_number() OVER (PARTITION BY day ORDER BY CASE WHEN total_hours BETWEEN 0 AND 16 THEN 0 ELSE 1 END, total_hours DESC) AS rn FROM daily_source) SELECT avg(CASE WHEN sleep_ms + awake_ms > 0 THEN sleep_ms::float / (sleep_ms + awake_ms) * 100.0 END) AS \"Sleep Efficiency %\" FROM ranked WHERE rn = 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          },
          "decimals": 1,
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
