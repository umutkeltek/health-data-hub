{
  "uid": "sleep-analysis",
  "title": "Sleep Analysis",
  "tags": [
    "health",
    "sleep"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "5m",
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Sleep Stages Timeline",
      "description": "Sleep stages over time showing transitions between deep, REM, core, and awake states",
      "type": "state-timeline",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT time, stage, duration_ms/60000.0 AS duration_min FROM sleep_stages WHERE stage IN ('core','deep','rem','awake') AND $__timeFilter(time) AND device_id IN ($device) ORDER BY time",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byValue",
              "options": {
                "op": "eq",
                "value": "deep"
              }
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byValue",
              "options": {
                "op": "eq",
                "value": "rem"
              }
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byValue",
              "options": {
                "op": "eq",
                "value": "core"
              }
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "light-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byValue",
              "options": {
                "op": "eq",
                "value": "awake"
              }
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showValue": "auto",
        "rowHeight": 0.8,
        "mergeValues": true,
        "alignValue": "center",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "title": "Sleep Duration Trend",
      "description": "Daily total sleep duration in hours (excluding awake and in-bed stages)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT date_trunc('day', time) AS time, CASE WHEN sum(duration_ms) FILTER (WHERE stage IN ('core','deep','rem')) > 0 THEN sum(duration_ms) FILTER (WHERE stage IN ('core','deep','rem')) / 3600000.0 ELSE sum(duration_ms) FILTER (WHERE stage = 'asleep') / 3600000.0 END AS hours FROM sleep_stages WHERE $__timeFilter(time) AND device_id IN ($device) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "fixed",
            "fixedColor": "super-light-blue"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "pointSize": 6,
            "lineWidth": 2,
            "showPoints": "always",
            "spanNulls": false,
            "axisBorderShow": false,
            "axisCenteredZero": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "green",
                "value": 7
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 3,
      "title": "Sleep Stage Distribution",
      "description": "Percentage breakdown of time spent in each sleep stage",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT stage, sum(duration_ms)/3600000.0 AS hours FROM sleep_stages WHERE stage IN ('core','deep','rem','awake') AND $__timeFilter(time) AND device_id IN ($device) GROUP BY stage ORDER BY hours DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "deep"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rem"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "dark-purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "core"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "light-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "awake"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "/^hours$/",
          "values": false
        },
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "percent",
            "value"
          ]
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "displayLabels": [
          "percent"
        ]
      }
    },
    {
      "id": 4,
      "title": "Deep Sleep Trend",
      "description": "Daily deep sleep duration in hours",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT date_trunc('day', time) AS time, sum(duration_ms)/3600000.0 AS deep_hours FROM sleep_stages WHERE stage='deep' AND $__timeFilter(time) AND device_id IN ($device) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "fixed",
            "fixedColor": "dark-blue"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "barAlignment": 0,
            "axisBorderShow": false
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "title": "REM Sleep Trend",
      "description": "Daily REM sleep duration in hours",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT date_trunc('day', time) AS time, sum(duration_ms)/3600000.0 AS rem_hours FROM sleep_stages WHERE stage='rem' AND $__timeFilter(time) AND device_id IN ($device) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "fixed",
            "fixedColor": "dark-purple"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "barAlignment": 0,
            "axisBorderShow": false
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 6,
      "title": "Avg Sleep Duration (7d)",
      "description": "Average total sleep duration over the last 7 days",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT avg(daily_hours) AS \"Avg Sleep (h)\" FROM ( SELECT date_trunc('day', time) AS day, CASE WHEN sum(duration_ms) FILTER (WHERE stage IN ('core','deep','rem')) > 0 THEN sum(duration_ms) FILTER (WHERE stage IN ('core','deep','rem')) / 3600000.0 ELSE sum(duration_ms) FILTER (WHERE stage = 'asleep') / 3600000.0 END AS daily_hours FROM sleep_stages WHERE time >= now() - interval '7 days' AND device_id IN ($device) GROUP BY 1 ) sub",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "green",
                "value": 7
              }
            ]
          },
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 7,
      "title": "Avg Deep Sleep (7d)",
      "description": "Average deep sleep duration over the last 7 days",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 24
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT avg(daily_hours) AS \"Avg Deep Sleep (h)\" FROM ( SELECT date_trunc('day', time) AS day, sum(duration_ms)/3600000.0 AS daily_hours FROM sleep_stages WHERE stage = 'deep' AND time >= now() - interval '7 days' AND device_id IN ($device) GROUP BY 1 ) sub",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "fixed",
            "fixedColor": "dark-blue"
          },
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 8,
      "title": "Avg REM Sleep (7d)",
      "description": "Average REM sleep duration over the last 7 days",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT avg(daily_hours) AS \"Avg REM Sleep (h)\" FROM ( SELECT date_trunc('day', time) AS day, sum(duration_ms)/3600000.0 AS daily_hours FROM sleep_stages WHERE stage = 'rem' AND time >= now() - interval '7 days' AND device_id IN ($device) GROUP BY 1 ) sub",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "fixed",
            "fixedColor": "dark-purple"
          },
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 9,
      "title": "Sleep Efficiency (7d)",
      "description": "Percentage of in-bed time actually spent sleeping over the last 7 days",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 24
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT CASE WHEN sum(duration_ms) FILTER (WHERE stage IN ('core','deep','rem','awake')) > 0 THEN (sum(duration_ms) FILTER (WHERE stage IN ('core','deep','rem')) * 100.0) / sum(duration_ms) FILTER (WHERE stage IN ('core','deep','rem','awake')) ELSE 0 END AS \"Sleep Efficiency %\" FROM sleep_stages WHERE stage IN ('core','deep','rem','awake') AND time >= now() - interval '7 days' AND device_id IN ($device)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          },
          "decimals": 1,
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 10,
      "title": "Wrist Temperature During Sleep",
      "description": "Body temperature readings from wrist sensor during sleep periods",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT time, temp_celsius FROM body_temperature WHERE $__timeFilter(time) ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": {
            "mode": "continuous-BlPu"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 4,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisBorderShow": false
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 11,
      "title": "Overnight HRV",
      "description": "Heart rate variability during sleep hours (10pm - 8am)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT time, value_ms FROM hrv WHERE (extract(hour from time) >= 22 OR extract(hour from time) <= 8) AND $__timeFilter(time) ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "fixed",
            "fixedColor": "super-light-purple"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 3,
            "lineWidth": 1,
            "showPoints": "auto",
            "spanNulls": false,
            "axisBorderShow": false
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 12,
      "title": "Sleep Duration by Device",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 100
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT date_trunc('day', ss.start_time) AS time, d.device_type AS metric, sum(ss.total_duration_ms) / 3600000.0 AS value FROM sleep_sessions ss JOIN devices d ON d.id = ss.device_id WHERE $__timeFilter(ss.start_time) AND ss.device_id IN ($device) GROUP BY 1, d.device_type ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "barAlignment": 0,
            "axisBorderShow": false
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 13,
      "title": "Sleep Efficiency: Apple Watch vs Whoop",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 108
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "SELECT d.device_type AS metric, avg(ss.sleep_efficiency_pct) AS value FROM sleep_sessions ss JOIN devices d ON d.id = ss.device_id WHERE $__timeFilter(ss.start_time) AND ss.device_id IN ($device) AND ss.sleep_efficiency_pct IS NOT NULL GROUP BY d.device_type",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          },
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    }
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
