    {
      "id": 12,
      "title": "Sleep Duration by Device",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 100
      },
      "datasource": {
        "type": "postgres",
        "uid": "healthsave-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "healthsave-pg"
          },
          "rawSql": "WITH daily_source AS (SELECT date_trunc('day', ss.start_time) AS time, d.device_type AS metric, COALESCE(NULLIF(ss.source_id, ''), 'Unknown') AS source, sum(ss.total_duration_ms) / 3600000.0 AS value FROM sleep_sessions ss JOIN devices d ON d.id = ss.device_id WHERE $__timeFilter(ss.start_time) AND ss.device_id IN ($device) GROUP BY 1, 2, 3), ranked AS (SELECT *, row_number() OVER (PARTITION BY time, metric ORDER BY CASE WHEN value BETWEEN 0 AND 16 THEN 0 ELSE 1 END, value DESC) AS rn FROM daily_source) SELECT time, metric, LEAST(value, 16) AS value FROM ranked WHERE rn = 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "barAlignment": 0,
            "axisBorderShow": false
          }
        }
      },
