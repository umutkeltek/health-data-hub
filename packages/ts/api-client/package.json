{
  "name": "@hdh/api-client",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "description": "TypeScript client for the HealthSave Observatory v2 read API and compatibility contracts.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./v1": "./src/v1.ts",
    "./v2": "./src/v2.ts"
  },
  "scripts": {
    "generate": "bun run scripts/generate.ts",
    "check": "bun run scripts/generate.ts --check",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "json-schema-to-typescript": "^15.0.4",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.7.3"
  }
}
